# Telegram бот (@special_kids_benefits_bot)
NGO_BOT_TOKEN=your-ngo-bot-token
ADMIN_CHAT_ID=your-admin-telegram-id

# AI-сервисы
OPENROUTER_API_KEY=your-openrouter-key
PERPLEXITY_API_KEY=your-perplexity-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Модели (опционально)
CLAUDE_MODEL=claude-sonnet-4-6
PERPLEXITY_MODEL=perplexity/sonar-pro

# Режим работы
BOT_MODE=polling
WEBAPP_PORT=8080
WEBHOOK_URL=

# Email (для отправки отчётов)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# TTS (не приоритет)
YANDEX_TTS_API_KEY=your-yandex-key
SBER_TTS_API_KEY=your-sber-key
